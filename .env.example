# ── MiddleEarth-Klip environment ───────────────────────────────────────────
# Copy to .env and adjust as needed:  cp .env.example .env

# ── Database ────────────────────────────────────────────────────────────────
# Local dev (host machine -> Postgres exposed on localhost:5432)
DATABASE_URL=postgres://middleearth:middleearth@localhost:5432/middleearth
# Docker-network variant (use when the backend runs inside docker compose,
# i.e. the "full" profile). The Postgres host is the service name "postgres".
# DATABASE_URL=postgres://middleearth:middleearth@postgres:5432/middleearth
#
# Host ports published by docker compose. Override these if 5432 / 3000 are
# already taken on your machine, then point DATABASE_URL at the new port.
# POSTGRES_PORT=5432
# BACKEND_PORT=3000

# ── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-please-use-a-long-random-secret
JWT_EXPIRES_IN=7d

# ── Backend server ──────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
NODE_ENV=development

# ── Object storage (MinIO, for avatar uploads) ───────────────────────────────
# Start it with:  docker compose up -d postgres minio
# Console (web UI): http://localhost:9001  (login with the keys below)
PUBLIC_API_URL=http://localhost:3000/api
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=middleearth
MINIO_SECRET_KEY=middleearth-minio-secret
MINIO_BUCKET=avatars
# MINIO_CONSOLE_PORT=9001

# ── Frontends (Vite) ────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000/api
VITE_DASHBOARD_URL=http://localhost:5174
