# ── MiddleEarth-Klip production env (VPS + Docker) ──────────────────────────
# Copy to .env on the server:  cp .env.prod.example .env   then edit the values.

# ── Domains (DNS A-records must point at this server's IP) ───────────────────
LANDING_DOMAIN=middleearth.example.com
DASHBOARD_DOMAIN=app.middleearth.example.com
API_DOMAIN=api.middleearth.example.com

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=middleearth
POSTGRES_DB=middleearth
# Use a strong, random value:  openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# ── Auth ────────────────────────────────────────────────────────────────────
# Use a long random secret:  openssl rand -base64 48
JWT_SECRET=CHANGE_ME_long_random_jwt_secret
JWT_EXPIRES_IN=7d
